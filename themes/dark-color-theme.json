{
	"name": "Dark (UFO)",
	"type": "dark",
	"colors": {
		"editor.background": "#121212", // Deep black for background
		"editor.foreground": "#E0E0E0", // Light gray for text
		"editorCursor.foreground": "#FF4500", // Bright orange for cursor
		"editor.lineHighlightBackground": "#1E1E1E", // Dark gray for line highlight
		"editor.selectionBackground": "#333333", // Medium gray for selection
		"editor.inactiveSelectionBackground": "#2A2A2A", // Darker gray for inactive selection
		"editorLineNumber.foreground": "#8A8A8A", // Subtle gray for line numbers
		"editorLineNumber.activeForeground": "#FF4500", // Bright orange for active line number
		"activityBar.background": "#1E1E1E", // Dark gray for activity bar
		"sideBar.background": "#1A1A1A", // Slightly lighter gray for sidebar
		"statusBar.background": "#1E1E1E", // Dark gray for status bar
		"tab.activeBackground": "#333333", // Active tab background
		"tab.inactiveBackground": "#121212", // Inactive tab background
		"tab.border": "#1E1E1E" // Border color for tabs
	},
	"tokenColors": [
		{
			"scope": [
				"comment",
				"punctuation.definition.comment",
				"string.comment"
			],
			"settings": {
				"foreground": "#8A8A8A" // Subtle gray for comments
			}
		},
		{
			"scope": [
				"variable",
				"variable.other",
				"variable.language"
			],
			"settings": {
				"foreground": "#FF4500" // Bright orange for variables
			}
		},
		{
			"scope": "keyword",
			"settings": {
				"foreground": "#FF6347" // Tomato red for keywords
			}
		},
		{
			"scope": "string",
			"settings": {
				"foreground": "#32CD32" // Lime green for strings
			}
		},
		{
			"scope": "constant.numeric",
			"settings": {
				"foreground": "#FFD700" // Gold for numbers
			}
		},
		{
			"scope": "entity.name.function",
			"settings": {
				"foreground": "#1E90FF" // Dodger blue for function names
			}
		},
		{
			"scope": "variable.parameter",
			"settings": {
				"foreground": "#FF69B4" // Pink for parameters
			}
		},
		{
			"scope": "storage.type",
			"settings": {
				"foreground": "#FF4500" // Bright orange for storage types
			}
		},
		{
			"scope": "entity.name.type",
			"settings": {
				"foreground": "#7B68EE" // Medium slate blue for types
			}
		}
	]
}