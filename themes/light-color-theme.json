{
	"name": "Light (UFO)",
	"type": "light",
	"colors": {
		"editor.background": "#FFFFFF", // Bright white for background
		"editor.foreground": "#333333", // Dark gray for text
		"editorCursor.foreground": "#FF4500", // Bright orange for cursor
		"editor.lineHighlightBackground": "#F0F0F0", // Light gray for line highlight
		"editor.selectionBackground": "#D3D3D3", // Soft gray for selection
		"editor.inactiveSelectionBackground": "#E8E8E8", // Lighter gray for inactive selection
		"editorLineNumber.foreground": "#A9A9A9", // Subtle gray for line numbers
		"editorLineNumber.activeForeground": "#FF4500", // Bright orange for active line number
		"activityBar.background": "#F8F8F8", // Light gray for activity bar
		"sideBar.background": "#F5F5F5", // Very light gray for sidebar
		"statusBar.background": "#F8F8F8", // Light gray for status bar
		"tab.activeBackground": "#E8E8E8", // Active tab background
		"tab.inactiveBackground": "#FFFFFF", // Inactive tab background
		"tab.border": "#F0F0F0" // Border color for tabs
	},
	"tokenColors": [
		{
			"scope": [
				"comment",
				"punctuation.definition.comment",
				"string.comment"
			],
			"settings": {
				"foreground": "#A9A9A9" // Subtle gray for comments
			}
		},
		{
			"scope": [
				"variable",
				"variable.other",
				"variable.language"
			],
			"settings": {
				"foreground": "#FF4500" // Bright orange for variables
			}
		},
		{
			"scope": "keyword",
			"settings": {
				"foreground": "#FF6347" // Tomato red for keywords
			}
		},
		{
			"scope": "string",
			"settings": {
				"foreground": "#32CD32" // Lime green for strings
			}
		},
		{
			"scope": "constant.numeric",
			"settings": {
				"foreground": "#FFD700" // Gold for numbers
			}
		},
		{
			"scope": "entity.name.function",
			"settings": {
				"foreground": "#1E90FF" // Dodger blue for function names
			}
		},
		{
			"scope": "variable.parameter",
			"settings": {
				"foreground": "#FF69B4" // Pink for parameters
			}
		},
		{
			"scope": "storage.type",
			"settings": {
				"foreground": "#FF4500" // Bright orange for storage types
			}
		},
		{
			"scope": "entity.name.type",
			"settings": {
				"foreground": "#7B68EE" // Medium slate blue for types
			}
		}
	]
}