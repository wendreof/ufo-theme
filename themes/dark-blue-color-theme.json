{
	"name": "Dark Blue (UFO)",
	"type": "dark",
	"colors": {
		"editor.background": "#0A0E1A", // Deep blue for background
		"editor.foreground": "#A8DADC", // Soft cyan for text
		"editorCursor.foreground": "#E63946", // Bright red for cursor
		"editor.lineHighlightBackground": "#1D3557", // Dark blue for line highlight
		"editor.selectionBackground": "#457B9D", // Muted blue for selection
		"editor.inactiveSelectionBackground": "#1D3557", // Darker blue for inactive selection
		"editorLineNumber.foreground": "#A8DADC", // Soft cyan for line numbers
		"editorLineNumber.activeForeground": "#E63946", // Bright red for active line number
		"activityBar.background": "#1D3557", // Dark blue for activity bar
		"sideBar.background": "#0A0E1A", // Deep blue for sidebar
		"statusBar.background": "#1D3557", // Dark blue for status bar
		"tab.activeBackground": "#457B9D", // Active tab background
		"tab.inactiveBackground": "#0A0E1A", // Inactive tab background
		"tab.border": "#1D3557" // Border color for tabs
	},
	"tokenColors": [
		{
			"scope": [
				"comment",
				"punctuation.definition.comment",
				"string.comment"
			],
			"settings": {
				"foreground": "#6C757D" // Gray for comments
			}
		},
		{
			"scope": [
				"variable",
				"variable.other",
				"variable.language"
			],
			"settings": {
				"foreground": "#E63946" // Bright red for variables
			}
		},
		{
			"scope": "keyword",
			"settings": {
				"foreground": "#F4A261" // Warm orange for keywords
			}
		},
		{
			"scope": "string",
			"settings": {
				"foreground": "#2A9D8F" // Teal for strings
			}
		},
		{
			"scope": "constant.numeric",
			"settings": {
				"foreground": "#E9C46A" // Golden yellow for numbers
			}
		},
		{
			"scope": "entity.name.function",
			"settings": {
				"foreground": "#1D3557" // Dark blue for function names
			}
		},
		{
			"scope": "variable.parameter",
			"settings": {
				"foreground": "#F4A261" // Warm orange for parameters
			}
		},
		{
			"scope": "storage.type",
			"settings": {
				"foreground": "#E63946" // Bright red for storage types
			}
		},
		{
			"scope": "entity.name.type",
			"settings": {
				"foreground": "#A8DADC" // Soft cyan for types
			}
		}
	]
}